{
  "name": "collaborative-code-editor",
  "version": "1.0.0",
  "main": "server/server.js",
  "type": "module",
  "workspaces": [
    "client"
  ],
  "scripts": {
    "install:all": "npm install && npm install --workspace=client",
    "dev": "npm run dev --workspace=client",
    "build": "npm install --workspace=client && npm run build --workspace=client",
    "server:dev": "nodemon server/server.js",
    "server:prod": "node server/server.js",
    "lint": "eslint client/src server",
    "lint:fix": "eslint client/src server --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "cors": "^2.8.5",
    "express": "^5.0.0",
    "socket.io": "^4.7.5",
    "tree-kill": "^1.2.2",
    "uuid": "^14.0.0"
  }
}
